# Coverage reports
coverage/

# Ruby
*.gem
*.rbc
/.config
/coverage/
/InstalledFiles
/pkg/
/spec/reports/
/spec/examples.txt
/test/tmp/
/test/version_tmp/
/tmp/

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore uploaded files in development.
/storage/*
!/storage/.keep

/public/assets
.byebug_history

# Ignore master key for decrypting credentials and more.
/config/master.key

# Ignore application configuration.
/config/application.yml

# vi/vim
*.swp

# Claude Code — ignore contents but keep project-local skills versioned
# (settings.json and worktrees stay local; skills are shared tooling).
.claude/*
!.claude/skills/

# Web page build artifacts — regenerated by `make build` from the
# canonical YAML files. The committed source is YAML; these JS/JSON
# bundles are deploy artifacts that lag commits by one SHA, so we
# keep them out of git to avoid the constant churn.
web/walkthrough/data.js
web/walkthrough/rules.json
web/walkthrough/questions.json
web/walkthrough/scenarios.json
web/quiz/data.js
web/quiz/rules.json
web/quiz/scenarios.json
web/text-verify/data.js
