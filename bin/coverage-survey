#!/usr/bin/env ruby
# frozen_string_literal: true

# bin/coverage-survey — find weak-coverage + smelly code to prioritize tests.
#
# Reads SimpleCov's coverage/.resultset.json for Ruby, walks web/{quiz,
# walkthrough,shared}/*.js for the front-end (which has no per-file
# coverage tool wired up yet — front-end is reported as tested/untested
# based on test-file references). Emits a markdown report on stdout.
#
# Usage:
#   bin/coverage-survey           # markdown report to stdout
#   bin/coverage-survey --json    # raw JSON instead (for scripting)
#
# No bundler — uses stdlib only so it runs even when gems aren't installed.

require 'json'
require 'set'

ROOT = File.expand_path('..', __dir__)
RESULTSET = File.join(ROOT, 'coverage', '.resultset.json')
RUBY_GLOB = File.join(ROOT, 'lib', '**', '*.rb')
JS_GLOBS  = %w[web/quiz web/walkthrough web/shared].map { |d| File.join(ROOT, d, '*.js') }
# Exclude generated artifacts and tool/test files from the runtime-JS report.
# - data.js: generated by `make build` (gitignored)
# - build.js: build tooling, not shipped to the browser
# - tests.js, test-*.js: test code itself
JS_RUNTIME_EXCLUDES = %w[data.js build.js tests.js].freeze
JS_TEST_GLOBS = [
  File.join(ROOT, 'web', '**', 'test-*.mjs'),
  File.join(ROOT, 'web', '**', 'test-*.js'),
  File.join(ROOT, 'web', '**', 'run-*tests*.mjs'),
].freeze
SMELL_METHOD_LINES = 40

# ---------------------------------------------------------------- Ruby coverage

def load_ruby_coverage
  return {} unless File.exist?(RESULTSET)

  data = JSON.parse(File.read(RESULTSET))
  data.values.first['coverage']
end

def ruby_file_stats(file_cov)
  lines = file_cov['lines'] || []
  exec = lines.compact
  hit = exec.count(&:positive?)
  uncovered_lines = lines.each_with_index
                         .select { |n, _| n == 0 }
                         .map { |_, i| i + 1 }

  branches = file_cov['branches'] || {}
  total_b = 0
  hit_b = 0
  uncov_branches = []
  branches.each_value do |inner|
    inner.each do |branch_key, hits|
      total_b += 1
      if hits.positive?
        hit_b += 1
      elsif (m = branch_key.match(/\[:([^,]+), \d+, (\d+),/))
        uncov_branches << { line: m[2].to_i, dir: m[1].delete('"').delete(':') }
      end
    end
  end

  {
    line_pct: exec.empty? ? 100.0 : (hit.to_f / exec.size * 100).round(1),
    branch_pct: total_b.zero? ? nil : (hit_b.to_f / total_b * 100).round(1),
    exec_lines: exec.size,
    total_branches: total_b,
    uncovered_lines: uncovered_lines,
    uncovered_branches: uncov_branches.sort_by { |b| b[:line] },
  }
end

# ---------------------------------------------------------------- Smell scans
# These use line-pattern heuristics, not a real parser. Good-enough for a
# survey; false positives/negatives are acceptable.

def scan_ruby_methods(path)
  lines = File.readlines(path)
  out = []
  i = 0
  while i < lines.size
    if (m = lines[i].match(/^(\s*)def\s+(self\.)?([^\s(]+)/))
      indent = m[1]
      name = m[3].sub(/[?!=]$/, '')
      end_re = /^#{Regexp.escape(indent)}end\s*$/
      j = i + 1
      j += 1 while j < lines.size && lines[j] !~ end_re
      length = j - i + 1
      out << { name: name, line: i + 1, length: length } if length > SMELL_METHOD_LINES
      i = j
    end
    i += 1
  end
  out
end

def scan_ruby_case_arity(path)
  src = File.read(path)
  out = []
  # For each `case` at some indent X, walk forward and count `when` at
  # indent X (or X+matching) until matching `end` at indent X.
  lines = src.lines
  i = 0
  while i < lines.size
    if (m = lines[i].match(/^(\s*)case\b/))
      indent = m[1]
      end_re = /^#{Regexp.escape(indent)}end\s*$/
      when_re = /^#{Regexp.escape(indent)}\s*when\b/
      whens = 0
      j = i + 1
      while j < lines.size && lines[j] !~ end_re
        whens += 1 if lines[j] =~ when_re
        j += 1
      end
      out << { line: i + 1, whens: whens } if whens > 4
      i = j
    end
    i += 1
  end
  out
end

def scan_js_functions(path)
  src = File.read(path)
  out = []
  # Match function declarations, named function expressions, and named
  # arrow functions. Skip anonymous expressions for simplicity.
  patterns = [
    /^\s*function\s+(\w+)\s*\([^)]*\)\s*\{/,
    /^\s*(\w+)\s*[:=]\s*function\s*\([^)]*\)\s*\{/,
    /^\s*(?:const|let|var)\s+(\w+)\s*=\s*\([^)]*\)\s*=>\s*\{/,
  ]
  patterns.each do |re|
    src.scan(re) do
      name = Regexp.last_match(1)
      start_idx = Regexp.last_match.begin(0)
      brace_pos = src.index('{', start_idx)
      next unless brace_pos

      depth = 1
      pos = brace_pos + 1
      while pos < src.length && depth.positive?
        ch = src[pos]
        depth += 1 if ch == '{'
        depth -= 1 if ch == '}'
        pos += 1
      end
      start_line = src[0...start_idx].count("\n") + 1
      end_line = src[0...pos].count("\n") + 1
      length = end_line - start_line + 1
      out << { name: name, line: start_line, length: length } if length > SMELL_METHOD_LINES
    end
  end
  out.uniq { |s| [s[:name], s[:line]] }.sort_by { |s| s[:line] }
end

# Cross-file duplication: for a fixed list of helper names we already know
# are duplicated (and any new candidate), flag every file that defines them.
DUPE_CANDIDATES = %w[escapeHtml wrapText pad repeat visualLength].freeze

def find_js_duplicates(js_files)
  out = {}
  DUPE_CANDIDATES.each do |name|
    files = js_files.select do |f|
      src = File.read(f)
      src.match?(/\bfunction\s+#{name}\b/) || src.match?(/\b#{name}\s*[:=]\s*function\b/)
    end
    out[name] = files if files.size > 1
  end
  out
end

# ---------------------------------------------------------------- JS test refs

def js_tested_set
  tested = Set.new
  JS_TEST_GLOBS.flat_map { |g| Dir.glob(g) }.uniq.each do |tf|
    src = File.read(tf)
    src.scan(/(?:require|from)\s*\(?\s*['"]([^'"]+)['"]/).each do |(rel)|
      next unless rel.start_with?('.', '/')

      base = File.expand_path(rel, File.dirname(tf))
      candidates = [base, "#{base}.js", "#{base}.mjs"]
      candidates.each { |c| tested << c if File.exist?(c) }
    end
  end
  tested
end

# ---------------------------------------------------------------- Reporting

def fmt_pct(p)
  return '  -- ' if p.nil?

  format('%5.1f', p)
end

def fmt_list(arr, limit = 8)
  return '' if arr.empty?

  shown = arr.first(limit).join(', ')
  arr.size > limit ? "#{shown}, +#{arr.size - limit}" : shown
end

def build_report
  ruby_cov = load_ruby_coverage
  ruby_files = Dir.glob(RUBY_GLOB).sort
  js_files = JS_GLOBS.flat_map { |g| Dir.glob(g) }
                     .reject { |p| JS_RUNTIME_EXCLUDES.include?(File.basename(p)) || p.start_with?(File.join(ROOT, 'web', 'shared', 'test-')) }
                     .sort
  tested_js = js_tested_set

  ruby_rows = ruby_files.map do |path|
    rel = path.sub("#{ROOT}/", '')
    cov = ruby_cov[path]
    if cov.nil?
      { file: rel, missing: true }
    else
      ruby_file_stats(cov).merge(file: rel)
    end
  end

  js_rows = js_files.map do |path|
    rel = path.sub("#{ROOT}/", '')
    { file: rel, lines: File.foreach(path).count, tested: tested_js.include?(path) }
  end

  ruby_smells = ruby_files.map do |path|
    rel = path.sub("#{ROOT}/", '')
    methods = scan_ruby_methods(path)
    cases   = scan_ruby_case_arity(path)
    next nil if methods.empty? && cases.empty?

    { file: rel, long_methods: methods, large_cases: cases }
  end.compact

  js_smells = js_files.map do |path|
    rel = path.sub("#{ROOT}/", '')
    fns = scan_js_functions(path)
    next nil if fns.empty?

    { file: rel, long_functions: fns }
  end.compact

  dupes = find_js_duplicates(js_files).transform_values do |files|
    files.map { |f| f.sub("#{ROOT}/", '') }
  end

  {
    generated_at: Time.now.utc.strftime('%Y-%m-%d %H:%M UTC'),
    ruby: ruby_rows,
    js: js_rows,
    ruby_smells: ruby_smells,
    js_smells: js_smells,
    js_duplicates: dupes,
  }
end

def print_markdown(report)
  puts '# Coverage Survey'
  puts
  puts "Generated #{report[:generated_at]}"
  puts

  # Priority callout: most actionable items first. Front-end leads because
  # untested JS modules are effectively at 0% coverage.
  untested = report[:js].reject { |r| r[:tested] }
  ruby_gaps = report[:ruby].reject { |r| r[:missing] || (r[:line_pct] == 100.0 && (r[:branch_pct].nil? || r[:branch_pct] == 100.0)) }
  ruby_missing = report[:ruby].select { |r| r[:missing] }
  if untested.any? || ruby_gaps.any? || ruby_missing.any?
    puts '## Priority — where coverage is weakest'
    puts
    if untested.any?
      puts "**Front-end (#{untested.size} untested runtime modules):**"
      untested.sort_by { |r| -r[:lines] }.first(8).each do |r|
        puts "- `#{r[:file]}` (#{r[:lines]} lines)"
      end
      puts
    end
    if ruby_missing.any?
      puts "**Ruby files with no coverage data:** #{ruby_missing.map { |r| "`#{r[:file]}`" }.join(', ')}"
      puts
    end
    if ruby_gaps.any?
      puts "**Ruby files below 100%:**"
      ruby_gaps.sort_by { |r| r[:line_pct] }.each do |r|
        puts "- `#{r[:file]}` — line #{fmt_pct(r[:line_pct])}%, branch #{fmt_pct(r[:branch_pct])}%"
      end
      puts
    end
  end

  puts '## Ruby coverage (lib/nasfaa/)'
  puts
  puts '| File | Exec lines | Line % | Branch % | Uncovered lines | Uncovered branches |'
  puts '|---|---:|---:|---:|---|---|'
  report[:ruby].each do |r|
    if r[:missing]
      puts "| #{r[:file]} | ? |   0.0 |   --  | _no coverage data_ | |"
    else
      ul = fmt_list(r[:uncovered_lines])
      ub = fmt_list(r[:uncovered_branches].map { |b| "L#{b[:line]}:#{b[:dir]}" })
      puts "| #{r[:file]} | #{r[:exec_lines]} | #{fmt_pct(r[:line_pct])} | #{fmt_pct(r[:branch_pct])} | #{ul} | #{ub} |"
    end
  end
  puts

  puts '## JS coverage (web/)'
  puts
  puts 'Front-end testing is the current priority. **untested** = no test file references the module.'
  puts
  puts '| File | Lines | Status |'
  puts '|---|---:|---|'
  report[:js].each do |r|
    status = r[:tested] ? 'tested' : '**untested**'
    puts "| #{r[:file]} | #{r[:lines]} | #{status} |"
  end
  puts

  puts '## Code smells'
  puts
  puts '### Ruby'
  if report[:ruby_smells].empty?
    puts '_None over thresholds._'
  else
    report[:ruby_smells].each do |s|
      s[:long_methods].each do |m|
        puts "- #{s[:file]}:#{m[:line]} `#{m[:name]}` — #{m[:length]} lines (long method)"
      end
      s[:large_cases].each do |c|
        puts "- #{s[:file]}:#{c[:line]} case statement with #{c[:whens]} when branches"
      end
    end
  end
  puts
  puts '### JS'
  if report[:js_smells].empty?
    puts '_None over thresholds._'
  else
    report[:js_smells].each do |s|
      s[:long_functions].each do |f|
        puts "- #{s[:file]}:#{f[:line]} `#{f[:name]}()` — #{f[:length]} lines (long function)"
      end
    end
  end
  puts
  puts '### Cross-file duplication (JS)'
  if report[:js_duplicates].empty?
    puts '_None of the watched helpers are duplicated._'
  else
    report[:js_duplicates].each do |name, files|
      puts "- `#{name}()` defined in: #{files.join(', ')}"
    end
  end
end

# ----------------------------------------------------------------- main

report = build_report
if ARGV.include?('--json')
  puts JSON.pretty_generate(report)
else
  print_markdown(report)
end
